# Enforce LF line endings for all text files. This normalizes CRLF quirks so
# prettier/eslint stop flagging "Delete `␍`" on Windows checkouts regardless
# of the user's `core.autocrlf` setting.
*                text=auto eol=lf
*.ts             text eol=lf
*.tsx            text eol=lf
*.js             text eol=lf
*.jsx            text eol=lf
*.cjs            text eol=lf
*.mjs            text eol=lf
*.css            text eol=lf
*.scss           text eol=lf
*.json           text eol=lf
*.md             text eol=lf
*.yml            text eol=lf
*.yaml           text eol=lf
*.html           text eol=lf
*.svg            text eol=lf
*.sh             text eol=lf

# Explicitly keep CRLF where Windows tooling really needs them (none right now)
# *.bat          text eol=crlf
